<Window x:Class="CalculatorZotovaK41.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" 
        Height="380" Width="250"
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen" 
        Topmost="True"
        Background="#0D0D0D"
        WindowStyle="None"
        BorderThickness="2"
        BorderBrush="#2A2A2A">

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Margin="8,8,8,5" CornerRadius="6" Background="#1A1A1A" BorderBrush="#333" BorderThickness="1">
            <TextBox x:Name="DisplayTextBox" 
                     Height="55" 
                     FontSize="26" 
                     FontWeight="SemiBold"
                     Background="Transparent" 
                     Foreground="#FFFFFF" 
                     BorderThickness="0"
                     HorizontalContentAlignment="Right" 
                     VerticalContentAlignment="Center"
                     Padding="10,0,10,0"
                     IsReadOnly="True"
                     Text="0"
                     FontFamily="Segoe UI"/>
        </Border>

        <!-- Сетка кнопок -->
        <Grid Grid.Row="1" Margin="6,0,6,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Строка 0 -->
            <Button Grid.Row="0" Grid.Column="0" Content="Del" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="16" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Del_Click"/>

            <Button Grid.Row="0" Grid.Column="1" Content="(" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="0" Grid.Column="2" Content=")" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="18" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="0" Grid.Column="3" Content="^" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <!-- Строка 1 -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="1" Grid.Column="1" Content="8" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="1" Grid.Column="2" Content="9" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="1" Grid.Column="3" Content="/" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="22" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="2" Grid.Column="0" Content="4" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="2" Grid.Column="1" Content="5" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="2" Grid.Column="2" Content="6" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="2" Grid.Column="3" Content="*" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="24" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <!-- Строка 3 -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="3" Grid.Column="1" Content="2" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="3" Grid.Column="2" Content="3" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="3" Grid.Column="3" Content="-" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="24" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <!-- Строка 4 -->
            <Button Grid.Row="4" Grid.Column="0" Content="0" Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="20" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="4" Grid.Column="1" Content="." Margin="2" Height="50"
                    Background="#4A7BB5" Foreground="White" FontSize="24" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>

            <Button Grid.Row="4" Grid.Column="2" Content="=" Margin="2" Height="50"
                    Background="#2A4F8F" Foreground="White" FontSize="22" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Result_click"/>

            <Button Grid.Row="4" Grid.Column="3" Content="+" Margin="2" Height="50"
                    Background="#3A5F8F" Foreground="White" FontSize="22" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Button_Click"/>
        </Grid>
    </Grid>
</Window> 



